# Build output
/dist/
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test / coverage artifacts
*.test
*.out
coverage.*
/coverage/

# Go workspace files
go.work
go.work.sum

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Transient codegen artifacts (S1-T03): the 3.1->3.0 down-convert input to
# oapi-codegen. api/openapi.yaml is the source of truth; pkg/proto/*.gen.go is
# committed; this intermediate is regenerated by `task gen:proto`.
/api/.gen/

# SECRETS — never commit private keys or signing material (CLAUDE.md).
# Only the PUBLIC update-signing test key is allowed (added in S1-T22).
*.pem
!build/keys/update_pub_test.pem
*.key
*.pfx
*.p12
secrets.*
*.env
.env

# stray go build artifacts (binaries built into repo root)
/mkfixtures

# generated Windows version-info resources (S1-T30; never committed)
*.syso
